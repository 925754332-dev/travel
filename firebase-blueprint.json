{
  "entities": {
    "Plan": {
      "title": "Plan",
      "description": "A travel plan generated by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the plan"
        },
        "destination": {
          "type": "string",
          "description": "The destination of the trip"
        },
        "origin": {
          "type": "string",
          "description": "The origin of the trip"
        },
        "days": {
          "type": "number",
          "description": "The duration of the trip in days"
        },
        "theme": {
          "type": "string",
          "description": "The theme of the trip"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The creation time of the plan in ISO format"
        },
        "data": {
          "type": "string",
          "description": "The serialized JSON string of the plan data"
        }
      },
      "required": ["userId", "destination", "origin", "days", "theme", "createdAt", "data"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A budget generated by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the budget"
        },
        "destination": {
          "type": "string",
          "description": "The destination of the trip"
        },
        "days": {
          "type": "number",
          "description": "The duration of the trip in days"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The creation time of the budget in ISO format"
        },
        "data": {
          "type": "string",
          "description": "The serialized JSON string of the budget data"
        }
      },
      "required": ["userId", "destination", "days", "createdAt", "data"]
    }
  },
  "firestore": {
    "/users/{userId}/plans/{planId}": {
      "schema": {
        "$ref": "#/entities/Plan"
      },
      "description": "Plans created by the user"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": {
        "$ref": "#/entities/Budget"
      },
      "description": "Budgets created by the user"
    }
  }
}
